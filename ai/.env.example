# Production auth settings
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_DATA_FILE=".data/auth.json"
AUTH_ALLOW_DEMO_CODE="false"

# Image generation provider: LiteLLM OpenAI-compatible image endpoint
LITELLM_API_BASE="https://your-litellm.example/v1"
LITELLM_API_KEY=""
LITELLM_IMAGE_MODEL="imagen-4.0-ultra"

# Set false only for local demos if you want /api/generate without auth
REQUIRE_AUTH_FOR_GENERATION="true"
